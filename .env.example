# ============================================================
# Forente Planeter — Environment Variables
# Copy to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_PASSWORD=change_me_db_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── API ───────────────────────────────────────────────────────
SECRET_KEY=change_me_very_long_random_secret_key_min_64_chars
SUPERADMIN_PASSWORD=change_me_superadmin_password
SUPERADMIN_EMAIL=admin@forenteplaneter.no
ENVIRONMENT=development

# ── JWT ───────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITE_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24

# ── SMTP2Go ───────────────────────────────────────────────────
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp2go_username
SMTP_PASSWORD=your_smtp2go_password
SMTP_FROM_EMAIL=noreply@forenteplaneter.no
SMTP_FROM_NAME=Forente Planeter

# ── Game ──────────────────────────────────────────────────────
GAME_NAME=Forente Planeter
GAME_BASE_URL=http://localhost:5173
INVITES_PER_PLAYER=100
INVITE_REWARD_METAL=10000
INVITE_REWARD_ENERGY=10000
INVITE_REWARD_GAS=10000
