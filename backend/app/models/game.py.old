from sqlalchemy import String, Boolean, Integer, BigInteger, DateTime, ForeignKey, JSON
from sqlalchemy.orm import Mapped, mapped_column, relationship
from sqlalchemy.dialects.postgresql import UUID, JSONB
from datetime import datetime, timezone
import uuid

from app.core.database import Base


class Ship(Base):
    __tablename__ = "ships"

    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    owner_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("users.id"), nullable=False)
    planet_id: Mapped[uuid.UUID | None] = mapped_column(UUID(as_uuid=True), ForeignKey("planets.id"), nullable=True)
    ship_type: Mapped[str] = mapped_column(String(20), nullable=False)
    quantity: Mapped[int] = mapped_column(Integer, default=1)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), default=lambda: datetime.now(timezone.utc))


class FleetMission(Base):
    __tablename__ = "fleet_missions"

    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    owner_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("users.id"), nullable=False)
    origin_planet_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("planets.id"), nullable=False)
    target_planet_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("planets.id"), nullable=False)
    mission_type: Mapped[str] = mapped_column(String(16), nullable=False)
    status: Mapped[str] = mapped_column(String(16), default="in_flight")
    depart_tick: Mapped[int] = mapped_column(Integer, nullable=False)
    arrive_tick: Mapped[int] = mapped_column(Integer, nullable=False)
    return_tick: Mapped[int | None] = mapped_column(Integer, nullable=True)
    cargo_metal: Mapped[int] = mapped_column(BigInteger, default=0)
    cargo_energy: Mapped[int] = mapped_column(BigInteger, default=0)
    cargo_gas: Mapped[int] = mapped_column(BigInteger, default=0)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), default=lambda: datetime.now(timezone.utc))

    ships: Mapped[list["FleetMissionShip"]] = relationship("FleetMissionShip", back_populates="mission")


class FleetMissionShip(Base):
    __tablename__ = "fleet_mission_ships"

    mission_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("fleet_missions.id", ondelete="CASCADE"), primary_key=True)
    ship_type: Mapped[str] = mapped_column(String(20), primary_key=True)
    quantity: Mapped[int] = mapped_column(Integer, nullable=False)

    mission: Mapped["FleetMission"] = relationship("FleetMission", back_populates="ships")


class BuildQueue(Base):
    __tablename__ = "build_queue"

    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    planet_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("planets.id", ondelete="CASCADE"), nullable=False)
    owner_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("users.id"), nullable=False)
    ship_type: Mapped[str] = mapped_column(String(20), nullable=False)
    quantity: Mapped[int] = mapped_column(Integer, default=1)
    ticks_remaining: Mapped[int] = mapped_column(Integer, nullable=False)
    ticks_total: Mapped[int] = mapped_column(Integer, nullable=False)
    status: Mapped[str] = mapped_column(String(16), default="queued")
    queue_position: Mapped[int] = mapped_column(Integer, default=1)
    metal_cost: Mapped[int] = mapped_column(Integer, default=0)
    energy_cost: Mapped[int] = mapped_column(Integer, default=0)
    gas_cost: Mapped[int] = mapped_column(Integer, default=0)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), default=lambda: datetime.now(timezone.utc))


class CombatLog(Base):
    __tablename__ = "combat_log"

    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    tick_number: Mapped[int] = mapped_column(Integer, nullable=False)
    planet_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("planets.id"), nullable=False)
    attacker_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("users.id"), nullable=False)
    defender_id: Mapped[uuid.UUID | None] = mapped_column(UUID(as_uuid=True), ForeignKey("users.id"), nullable=True)
    attacker_won: Mapped[bool] = mapped_column(Boolean, nullable=False)
    attacker_atk_total: Mapped[int] = mapped_column(Integer, nullable=False)
    defender_atk_total: Mapped[int] = mapped_column(Integer, nullable=False)
    planet_changed_owner: Mapped[bool] = mapped_column(Boolean, default=False)
    losses_json: Mapped[dict] = mapped_column(JSONB, default=dict)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), default=lambda: datetime.now(timezone.utc))


class TickLog(Base):
    __tablename__ = "tick_log"

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    tick_number: Mapped[int] = mapped_column(Integer, unique=True, nullable=False)
    round_id: Mapped[int | None] = mapped_column(Integer, ForeignKey("game_round.id"), nullable=True)
    started_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), default=lambda: datetime.now(timezone.utc))
    ended_at: Mapped[datetime | None] = mapped_column(DateTime(timezone=True), nullable=True)
    planets_processed: Mapped[int] = mapped_column(Integer, default=0)
    missions_resolved: Mapped[int] = mapped_column(Integer, default=0)
    combats_resolved: Mapped[int] = mapped_column(Integer, default=0)
    status: Mapped[str] = mapped_column(String(16), default="running")


class Notification(Base):
    __tablename__ = "notifications"

    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    user_id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), ForeignKey("users.id", ondelete="CASCADE"), nullable=False)
    type: Mapped[str] = mapped_column(String(32), nullable=False)
    title: Mapped[str] = mapped_column(String(128), nullable=False)
    body: Mapped[str | None] = mapped_column(String, nullable=True)
    is_read: Mapped[bool] = mapped_column(Boolean, default=False)
    related_id: Mapped[uuid.UUID | None] = mapped_column(UUID(as_uuid=True), nullable=True)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), default=lambda: datetime.now(timezone.utc))
